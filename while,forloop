# Print numbers divisible by 3 but not by 5 (1–30)


for i in range(1, 31):
    if i % 3 == 0 and i % 5 != 0:
        print(i)

# Reverse a number using while loop

num = 1234
rev = 0

while num > 0:
    digit = num % 10
    rev = rev * 10 + digit
    num //= 10

print(rev)

# Count digits in a number
num = 98765
count = 0

while num > 0:
    count += 1
    num //= 10

print(count)

