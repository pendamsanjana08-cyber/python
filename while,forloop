# Find factorial using loop

n = 5
fact = 1
for i in range(1, n + 1):
    fact *= i
print(fact)

# Check if a number is prime

num = 7
is_prime = True
for i in range(2, num):
    if num % i == 0:
        is_prime = False
        break
if is_prime and num > 1:
    print("Prime")
else:
    print("Not Prime")

